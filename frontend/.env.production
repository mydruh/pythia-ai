# ── Frontend PROD (Vite, читается при `vite build`) ──────────────
# Прод-режим Mini App: дашборд доступен ТОЛЬКО через Telegram (без браузера).
VITE_ALLOW_BROWSER=false

# VITE_API_URL НЕ задаём здесь — он зависит от деплоя бэкенда.
# Задай его в переменных окружения Vercel:
#   VITE_API_URL=https://<твой-backend>.up.railway.app
# Без него фронт будет стучаться в относительный /api и получит 404.
