# ── Frontend (Vite) ─────────────────────────────────────────────
# Скопируй в frontend/.env и поправь под себя.

# Базовый URL API. Локально не нужен — vite-прокси шлёт /api на localhost:8000.
# Для деплоя на отдельный домен укажи полный URL бэкенда.
# VITE_API_URL=https://api.example.com

# Разрешить открывать дашборд в обычном браузере без Telegram.
#   true  — режим разработки: дашборд доступен на http://localhost:5173
#   false — прод: дашборд только через Telegram Mini App (по умолчанию)
VITE_ALLOW_BROWSER=true

# uid по умолчанию, под которым открывается дашборд в браузерном режиме.
# Должен совпадать с telegram_id пользователя, созданного через POST /users/start.
VITE_DEV_UID=1
