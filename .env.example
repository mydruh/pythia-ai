# ── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather → создать бота → скопировать токен
WEBAPP_URL=https://your-frontend.vercel.app  # URL задеплоенного React Mini App

# ── Auth ────────────────────────────────────────────────────────
# Общий секрет для server-to-server (бот -> API). Сгенерируй случайную строку.
INTERNAL_API_TOKEN=
# true — разрешить запросы без проверки Telegram initData (ЛОКАЛЬНАЯ разработка
# в браузере). В ПРОДЕ обязательно false (или не задавать).
ALLOW_UNVERIFIED_AUTH=false

# ── LLM providers ───────────────────────────────────────────────
GROQ_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=          # опционально (A/B по калибровке)

# ── Polymarket / Polygon ────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=     # приватный ключ кошелька бота (ОТДЕЛЬНЫЙ!)
POLYMARKET_FUNDER=          # адрес кошелька

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pythia:pythia@localhost:5432/pythia

# ── Trading mode & risk limits ──────────────────────────────────
TRADING_MODE=paper          # paper | live
RISK_MAX_POSITION_PCT=0.05  # макс. доля банка на одну позицию
RISK_MAX_EXPOSURE_PCT=0.50  # макс. суммарная экспозиция
RISK_MAX_DRAWDOWN_PCT=0.20  # стоп по просадке -> остановка бота
RISK_MIN_EDGE=0.10          # минимальный |my_prob - market_prob|
RISK_MIN_VOLUME=1000        # фильтр ликвидности (USDC)

# ── Доп. риск-предохранители (есть дефолты, менять опционально) ──
RISK_MIN_CONVICTION=0.10    # мин. |my_prob-0.5|: <- модель near-0.5 = «не знаю», не входим
RISK_MIN_HOURS_TO_CLOSE=2   # не входить в рынки, закрывающиеся раньше (стоп-лосс не успеет)
RISK_MAX_POSITIONS_PER_EVENT=2   # макс. ставок на одно событие (матч/город-день)
RISK_MAX_EVENT_EXPOSURE_PCT=0.10 # макс. доля капитала на одно событие
STOP_LOSS_CHECK_SECONDS=60  # частота фоновой проверки стоп-лосса/урегулирования

# ── Analyzer ────────────────────────────────────────────────────
FILTER_MODEL=llama-3.1-8b-instant
DECISION_MODEL=grok-4.3
DECISION_PROVIDER=grok      # groq | grok | claude
# Модель Groq для слоя решений: при DECISION_PROVIDER=groq и как фоллбэк,
# когда XAI_API_KEY/ANTHROPIC_API_KEY пустой или провайдер недоступен.
GROQ_DECISION_MODEL=llama-3.3-70b-versatile

# ── Capital / cycle ─────────────────────────────────────────────
STARTING_BANKROLL=1000      # стартовый банк (USDC) для paper
CYCLE_INTERVAL_MINUTES=30   # период торгового цикла
